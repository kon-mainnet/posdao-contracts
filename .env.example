# KONET scripts configuration.
# Copy to `.env` and fill in. `.env` is gitignored; only `.env.example` is committed.
# Existing shell environment variables take precedence over values in `.env`.

# =============================================================================
# A) FRESH DEPLOYMENT INPUTS  (scripts/deploy_for_konet.js)
#    Deploys a NEW POSDAO contract set (fresh implementations + fresh proxies) onto an
#    already-running KONET chain. Fresh proxies only; upgrading an already-deployed proxy is
#    out of scope for this script.
#
#    Signing model: this script signs RAW transactions with private keys from this file. It does
#    NOT rely on a node keystore, unlocked accounts, or provider-managed accounts. Any plain HTTP
#    RPC endpoint (KONET_RPC_URL) is sufficient. NEVER commit real private keys — `.env` is
#    gitignored; only this `.env.example` (with empty values) is committed.
# =============================================================================

# RPC / execution
KONET_RPC_URL=
KONET_DEPLOY_MODE=fresh-proxy
KONET_EXECUTE=false
KONET_EXPECTED_CHAIN_ID=
KONET_ALLOW_MAINNET_EXECUTE=false
KONET_MAINNET_CHAIN_ID=

# roles (proxy admin MUST differ from operational owner)
KONET_DEPLOYER=
KONET_PROXY_ADMIN=
KONET_OPERATIONAL_OWNER=

# signing keys - DO NOT COMMIT REAL VALUES
# KONET_DEPLOYER_PRIVATE_KEY signs implementation/proxy creation transactions.
# KONET_PROXY_ADMIN_PRIVATE_KEY signs the upgradeToAndCall (initialize) transactions.
# Each key's recovered address must equal its role address above. If KONET_DEPLOYER ==
# KONET_PROXY_ADMIN the two key values may be identical. Do NOT add an operational-owner key:
# the operational owner is only the initialize() _owner and sends no transactions here.
KONET_DEPLOYER_PRIVATE_KEY=
KONET_PROXY_ADMIN_PRIVATE_KEY=

# optional gas config
KONET_GAS_PRICE=
KONET_GAS_LIMIT_MULTIPLIER_BPS=12000

# initial validators (comma-separated; mining and staking lengths must match)
KONET_INITIAL_MINING_ADDRESSES=
KONET_INITIAL_STAKING_ADDRESSES=
KONET_FIRST_VALIDATOR_IS_UNREMOVABLE=false

# staking params
KONET_DELEGATOR_MIN_STAKE=
KONET_CANDIDATE_MIN_STAKE=
KONET_STAKING_EPOCH_DURATION=
KONET_STAKING_EPOCH_START_BLOCK=
KONET_STAKE_WITHDRAW_DISALLOW_PERIOD=

# random params
KONET_COLLECT_ROUND_LENGTH=
KONET_PUNISH_FOR_UNREVEAL=true

# permission / certifier params (comma-separated address lists)
KONET_ALLOWED_ADDRESSES=
KONET_CERTIFIED_ADDRESSES=

# block reward (no silent default; use the zero address explicitly for a fresh deploy)
KONET_PREV_BLOCK_REWARD=0x0000000000000000000000000000000000000000

# =============================================================================
# B) EVIDENCE INSPECTOR  (scripts/inspect_konet_onchain_evidence.js)
#    Read-only inspection of ALREADY-DEPLOYED proxies. After a fresh deploy, paste the
#    *_PROXY addresses printed by deploy_for_konet.js into the variables below.
#    (KONET_RPC_URL and KONET_EXPECTED_CHAIN_ID from section A are shared.)
# =============================================================================

# Source / evidence metadata
KONET_SOURCE_COMMIT=
KONET_EVIDENCE_OUTPUT_JSON=reports/konet-onchain-evidence.json
KONET_EVIDENCE_OUTPUT_MD=reports/konet-onchain-evidence.md

# Owner-managed proxy addresses (deployed proxies to inspect)
KONET_CERTIFIER_PROXY=
KONET_GOVERNANCE_PROXY=
KONET_RANDOM_PROXY=
KONET_BLOCK_REWARD_PROXY=
KONET_STAKING_PROXY=
KONET_TX_PERMISSION_PROXY=

# Expected system dependency addresses for cross-check, optional but recommended
KONET_VALIDATOR_SET_PROXY=
KONET_EXPECTED_CERTIFIER_PROXY=
KONET_EXPECTED_GOVERNANCE_PROXY=

# Optional expected implementation addresses
KONET_CERTIFIER_IMPL_EXPECTED=
KONET_GOVERNANCE_IMPL_EXPECTED=
KONET_RANDOM_IMPL_EXPECTED=
KONET_BLOCK_REWARD_IMPL_EXPECTED=
KONET_STAKING_IMPL_EXPECTED=
KONET_TX_PERMISSION_IMPL_EXPECTED=
